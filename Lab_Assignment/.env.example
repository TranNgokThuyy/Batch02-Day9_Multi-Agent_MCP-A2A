# Copy file này thành .env rồi điền key sau.

# Weaviate local Docker
WEAVIATE_URL=http://localhost:8080
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION=RAGDocument

# OpenAI dùng cho Task 10 generation. Có thể để trống, code sẽ dùng extractive fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Jina AI dùng cho Task 7 reranking. Có thể để trống, code fallback local rerank.
JINA_API_KEY=

# PageIndex dùng cho Task 8 fallback.
# Trên dashboard PageIndex: tạo API key, upload tài liệu trong Documents, copy Document ID/doc_id.
PAGEINDEX_API_KEY=
PAGEINDEX_DOC_ID=

# Embedding model dùng để tạo vector trước khi push lên Weaviate.
# Nếu không tải được model, code fallback sang local hash embedding dimension=384.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
